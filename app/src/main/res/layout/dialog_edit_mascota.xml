<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvEditMascotaTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Editar Mascota"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nombre -->
    <EditText
        android:id="@+id/etNombreMascotaDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nombre"
        android:inputType="textCapWords"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvEditMascotaTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Especie -->
    <EditText
        android:id="@+id/etEspecieMascotaDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Especie"
        android:inputType="textCapWords"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etNombreMascotaDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Edad -->
    <EditText
        android:id="@+id/etEdadMascotaDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Edad (años)"
        android:inputType="number"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/etEspecieMascotaDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/etPesoMascotaDialog" />

    <!-- Peso -->
    <EditText
        android:id="@+id/etPesoMascotaDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Peso (kg)"
        android:inputType="numberDecimal"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/etEdadMascotaDialog"
        app:layout_constraintStart_toEndOf="@id/etEdadMascotaDialog"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botones -->
    <Button
        android:id="@+id/btnCancelEditMascota"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/etEdadMascotaDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSaveEditMascota" />

    <Button
        android:id="@+id/btnSaveEditMascota"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Guardar"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/btnCancelEditMascota"
        app:layout_constraintStart_toEndOf="@id/btnCancelEditMascota"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>