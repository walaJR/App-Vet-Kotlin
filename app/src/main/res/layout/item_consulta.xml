<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardConsulta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Mascota -->
        <TextView
            android:id="@+id/tvMascotaConsulta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Firulais (Perro)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvEstadoConsulta" />

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstadoConsulta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Pendiente"
            android:padding="8dp"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tipo de Servicio -->
        <TextView
            android:id="@+id/tvTipoServicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Consulta General"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvMascotaConsulta"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvFechaConsulta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 15/01/2026 10:00"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTipoServicio"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Veterinario -->
        <TextView
            android:id="@+id/tvVeterinario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="👨‍⚕️ Dr. García"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvFechaConsulta"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvCostoConsulta" />

        <!-- Costo -->
        <TextView
            android:id="@+id/tvCostoConsulta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$45.000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/success"
            app:layout_constraintTop_toTopOf="@id/tvVeterinario"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divisor -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvVeterinario"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Botón Compartir -->
        <ImageButton
            android:id="@+id/btnCompartirConsulta"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Compartir consulta"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteConsulta" />

        <!-- Botón Eliminar -->
        <ImageButton
            android:id="@+id/btnDeleteConsulta"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar consulta"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>